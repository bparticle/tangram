# Neon Postgres connection string (Project → Connection details).
DATABASE=postgres://user:password@host/db?sslmode=require

# Password for the single level-author account. Set a strong value.
ADMIN_PASSWORD=

# Secret used to derive session cookies. Any long random string, e.g.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotating it logs the author out everywhere.
SESSION_SECRET=
